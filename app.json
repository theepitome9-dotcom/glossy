{
  "name": "Glossy",
  "slug": "glossy",
  "scheme": "glossy",
  "version": "1.0.0",
  "orientation": "portrait",
  "icon": "./assets/icon.png",
  "userInterfaceStyle": "light",

  "splash": {
    "image": "./assets/splash.png",
    "resizeMode": "contain",
    "backgroundColor": "#000000"
  },

  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.glossy.paintingestimator",
    "buildNumber": "1"
  },

  "android": {
    "package": "com.glossy.paintingestimator",
    "versionCode": 1,
    "adaptiveIcon": {
      "foregroundImage": "./assets/icon.png",
      "backgroundColor": "#000000"
    },
    "permissions": [
      "CAMERA",
      "READ_EXTERNAL_STORAGE",
      "WRITE_EXTERNAL_STORAGE",
      "READ_MEDIA_IMAGES"
    ]
  },

  "plugins": [
    [
      "expo-build-properties",
      {
        "android": {
          "compileSdkVersion": 35,
          "targetSdkVersion": 35,
          "buildToolsVersion": "35.0.0",
          "minSdkVersion": 24,
          "ndkVersion": "26.1.10909125",
          "kotlinVersion": "2.0.21"
        }
      }
    ],
    "expo-asset",
    "expo-font",
    "expo-mail-composer",
    "expo-secure-store",
    "expo-sqlite",
    "expo-video",
    "expo-web-browser"
  ],

  "extra": {
    "eas": {
      "projectId": "edb7b13e-edac-41ba-855f-048665ac4efb"
    }
  },

  "sdkVersion": "53.0.0",
  "platforms": ["ios", "android", "web"]
}

